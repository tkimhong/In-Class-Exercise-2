<h1>Fuel Records Dashboard</h1>
<a href="/records/add" style="margin-bottom: 20px; display: inline-block;">+ Add New Record</a>

<table border="1" cellpadding="10" cellspacing="0" style="width: 100%; text-align: left;">
    <thead>
        <tr>
            <th>Date</th>
            <th>Vehicle</th>
            <th>Liters</th>
            <th>Distance (km)</th>
            <th>Total Cost</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {{#each records}}
        <tr>
            <td>{{this.date}}</td>
            <td>{{this.vehicleType}}</td>
            <td>{{this.liters}}</td>
            <td>{{this.distance}}</td>
            <td>${{this.totalCost}}</td>
            <td>
                <a href="/records/edit/{{this.id}}">Edit</a> | 
                <form action="/records/delete/{{this.id}}" method="POST" style="display:inline;">
                    <!-- CSRF Token for Delete -->
                    <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                    <button type="submit" onclick="return confirm('Delete this record?');">Delete</button>
                </form>
            </td>
        </tr>
        {{else}}
        <tr>
            <td colspan="6">No fuel records found.</td>
        </tr>
        {{/each}}
    </tbody>
</table>