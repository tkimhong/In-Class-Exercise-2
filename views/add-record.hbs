<h1>Add Fuel Record</h1>

<form action="/records/add" method="POST">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    <div>
        <label>Date:</label><br>
        <input type="date" name="date" required>
    </div>
    <br>
    <div>
        <label>Vehicle Type:</label><br>
        <select name="vehicleType" required>
            <option value="Car">Car</option>
            <option value="Motorcycle">Motorcycle</option>
        </select>
    </div>
    <br>
    <div>
        <label>Liters:</label><br>
        <input type="number" step="0.01" name="liters" required>
    </div>
    <br>
    <div>
        <label>Distance Traveled (km):</label><br>
        <input type="number" step="0.1" name="distance" required>
    </div>
    <br>
    <div>
        <label>Total Cost:</label><br>
        <input type="number" step="0.01" name="totalCost" required>
    </div>
    <br>
    <button type="submit">Save Record</button>
    <a href="/dashboard">Cancel</a>
</form>