<h1>Edit Fuel Record</h1>

<form action="/records/edit/{{record.id}}" method="POST">
    <!-- CSRF Token -->
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    <div>
        <label>Date:</label><br>
        <input type="date" name="date" value="{{record.date}}" required>
    </div>
    <br>
    <div>
        <label>Vehicle Type:</label><br>
        <select name="vehicleType" required>
            <option value="Car" {{#if (eq record.vehicleType 'Car')}}selected{{/if}}>Car</option>
            <option value="Motorcycle" {{#if (eq record.vehicleType 'Motorcycle')}}selected{{/if}}>Motorcycle</option>
        </select>
    </div>
    <br>
    <div>
        <label>Liters:</label><br>
        <input type="number" step="0.01" name="liters" value="{{record.liters}}" required>
    </div>
    <br>
    <div>
        <label>Distance Traveled (km):</label><br>
        <input type="number" step="0.1" name="distance" value="{{record.distance}}" required>
    </div>
    <br>
    <div>
        <label>Total Cost:</label><br>
        <input type="number" step="0.01" name="totalCost" value="{{record.totalCost}}" required>
    </div>
    <br>
    <button type="submit">Update Record</button>
    <a href="/dashboard">Cancel</a>
</form>